FROM nginx:alpine

# RPMs arrive pre-distributed into bucket subdirs (b00, b01, ...) with
# repodata/ alongside, all prepared by sync_repo.sh ON THE RUNNER. This
# Dockerfile only assembles the served image: each bucket is COPY'd as its own
# layer into the flat served dir, so a build that changes one bucket only moves
# that layer, and the always-changing repodata is a separate small layer. The
# served dir is flat (all *.rpm + repodata at /rpm-repo/), so the dnf baseurl
# is unchanged.
#
# There is deliberately NO builder stage: createrepo_c used to run in one here,
# assembling a flat view with cp -l, but hardlinks cannot cross overlayfs
# layers inside a build, so it silently fell back to cp -a and duplicated the
# entire multi-GB RPM set -- overflowing the runner disk once the repo grew.
# sync_repo.sh now hardlinks + runs createrepo_c on the runner filesystem
# (where links work and cost nothing) and ships only repodata/ extra.
#
# NOTE: the number of "COPY ... b<NN>/" lines below MUST equal NUM_BUCKETS in
# sync_repo.sh (currently 32). sync_repo.sh has a guard that fails the build if
# they disagree.

# Remove default nginx config
RUN rm /etc/nginx/conf.d/default.conf

# Serve the RPM repo on port 8080 at /rpm-repo/
RUN echo 'server { \
    listen 8080; \
    root /usr/share/nginx/html; \
    autoindex on; \
    location / { \
        try_files $uri $uri/ =404; \
    } \
}' > /etc/nginx/conf.d/rpm-repo.conf

# One COPY per bucket -> one layer per bucket, all flattened into the served
# dir. Unchanged buckets are identical layers and stay cached on push/pull.
COPY rpm-repo/b00/ /usr/share/nginx/html/rpm-repo/
COPY rpm-repo/b01/ /usr/share/nginx/html/rpm-repo/
COPY rpm-repo/b02/ /usr/share/nginx/html/rpm-repo/
COPY rpm-repo/b03/ /usr/share/nginx/html/rpm-repo/
COPY rpm-repo/b04/ /usr/share/nginx/html/rpm-repo/
COPY rpm-repo/b05/ /usr/share/nginx/html/rpm-repo/
COPY rpm-repo/b06/ /usr/share/nginx/html/rpm-repo/
COPY rpm-repo/b07/ /usr/share/nginx/html/rpm-repo/
COPY rpm-repo/b08/ /usr/share/nginx/html/rpm-repo/
COPY rpm-repo/b09/ /usr/share/nginx/html/rpm-repo/
COPY rpm-repo/b10/ /usr/share/nginx/html/rpm-repo/
COPY rpm-repo/b11/ /usr/share/nginx/html/rpm-repo/
COPY rpm-repo/b12/ /usr/share/nginx/html/rpm-repo/
COPY rpm-repo/b13/ /usr/share/nginx/html/rpm-repo/
COPY rpm-repo/b14/ /usr/share/nginx/html/rpm-repo/
COPY rpm-repo/b15/ /usr/share/nginx/html/rpm-repo/
COPY rpm-repo/b16/ /usr/share/nginx/html/rpm-repo/
COPY rpm-repo/b17/ /usr/share/nginx/html/rpm-repo/
COPY rpm-repo/b18/ /usr/share/nginx/html/rpm-repo/
COPY rpm-repo/b19/ /usr/share/nginx/html/rpm-repo/
COPY rpm-repo/b20/ /usr/share/nginx/html/rpm-repo/
COPY rpm-repo/b21/ /usr/share/nginx/html/rpm-repo/
COPY rpm-repo/b22/ /usr/share/nginx/html/rpm-repo/
COPY rpm-repo/b23/ /usr/share/nginx/html/rpm-repo/
COPY rpm-repo/b24/ /usr/share/nginx/html/rpm-repo/
COPY rpm-repo/b25/ /usr/share/nginx/html/rpm-repo/
COPY rpm-repo/b26/ /usr/share/nginx/html/rpm-repo/
COPY rpm-repo/b27/ /usr/share/nginx/html/rpm-repo/
COPY rpm-repo/b28/ /usr/share/nginx/html/rpm-repo/
COPY rpm-repo/b29/ /usr/share/nginx/html/rpm-repo/
COPY rpm-repo/b30/ /usr/share/nginx/html/rpm-repo/
COPY rpm-repo/b31/ /usr/share/nginx/html/rpm-repo/

# repodata last, as its own small layer (regenerated every build).
COPY rpm-repo/repodata/ /usr/share/nginx/html/rpm-repo/repodata/

EXPOSE 8080

CMD ["nginx", "-g", "daemon off;"]
