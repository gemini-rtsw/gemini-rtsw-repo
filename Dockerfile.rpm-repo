FROM rockylinux:9 AS builder

RUN dnf install -y createrepo_c && dnf clean all

# RPMs arrive pre-distributed into bucket subdirs (b00, b01, ...) by
# sync_repo.sh. Keep them in buckets in the builder, run createrepo over the
# whole set, then in the FINAL stage copy each bucket as its own layer into the
# flat served dir. That way the pushed/pulled image stores RPMs across many
# stable layers: a build that changes one bucket only moves that layer, and the
# always-changing repodata is a separate small layer. The served dir is still
# flat (all *.rpm + repodata at /rpm-repo/), so the dnf baseurl is unchanged.
#
# NOTE: the number of "COPY ... b<NN>/" lines below MUST equal NUM_BUCKETS in
# sync_repo.sh (currently 32). sync_repo.sh has a guard that fails the build if
# they disagree.
COPY rpm-repo/ /build/buckets/

# createrepo needs all RPMs in one dir; assemble a flat view, index it.
RUN mkdir -p /build/flat && \
    for d in /build/buckets/b*/; do cp -a "$d"*.rpm /build/flat/ 2>/dev/null || true; done && \
    createrepo_c /build/flat/

FROM nginx:alpine

# Remove default nginx config
RUN rm /etc/nginx/conf.d/default.conf

# Serve the RPM repo on port 8080 at /rpm-repo/
RUN echo 'server { \
    listen 8080; \
    root /usr/share/nginx/html; \
    autoindex on; \
    location / { \
        try_files $uri $uri/ =404; \
    } \
}' > /etc/nginx/conf.d/rpm-repo.conf

# One COPY per bucket -> one layer per bucket, all flattened into the served
# dir. Unchanged buckets are identical layers and stay cached on push/pull.
COPY --from=builder /build/buckets/b00/ /usr/share/nginx/html/rpm-repo/
COPY --from=builder /build/buckets/b01/ /usr/share/nginx/html/rpm-repo/
COPY --from=builder /build/buckets/b02/ /usr/share/nginx/html/rpm-repo/
COPY --from=builder /build/buckets/b03/ /usr/share/nginx/html/rpm-repo/
COPY --from=builder /build/buckets/b04/ /usr/share/nginx/html/rpm-repo/
COPY --from=builder /build/buckets/b05/ /usr/share/nginx/html/rpm-repo/
COPY --from=builder /build/buckets/b06/ /usr/share/nginx/html/rpm-repo/
COPY --from=builder /build/buckets/b07/ /usr/share/nginx/html/rpm-repo/
COPY --from=builder /build/buckets/b08/ /usr/share/nginx/html/rpm-repo/
COPY --from=builder /build/buckets/b09/ /usr/share/nginx/html/rpm-repo/
COPY --from=builder /build/buckets/b10/ /usr/share/nginx/html/rpm-repo/
COPY --from=builder /build/buckets/b11/ /usr/share/nginx/html/rpm-repo/
COPY --from=builder /build/buckets/b12/ /usr/share/nginx/html/rpm-repo/
COPY --from=builder /build/buckets/b13/ /usr/share/nginx/html/rpm-repo/
COPY --from=builder /build/buckets/b14/ /usr/share/nginx/html/rpm-repo/
COPY --from=builder /build/buckets/b15/ /usr/share/nginx/html/rpm-repo/
COPY --from=builder /build/buckets/b16/ /usr/share/nginx/html/rpm-repo/
COPY --from=builder /build/buckets/b17/ /usr/share/nginx/html/rpm-repo/
COPY --from=builder /build/buckets/b18/ /usr/share/nginx/html/rpm-repo/
COPY --from=builder /build/buckets/b19/ /usr/share/nginx/html/rpm-repo/
COPY --from=builder /build/buckets/b20/ /usr/share/nginx/html/rpm-repo/
COPY --from=builder /build/buckets/b21/ /usr/share/nginx/html/rpm-repo/
COPY --from=builder /build/buckets/b22/ /usr/share/nginx/html/rpm-repo/
COPY --from=builder /build/buckets/b23/ /usr/share/nginx/html/rpm-repo/
COPY --from=builder /build/buckets/b24/ /usr/share/nginx/html/rpm-repo/
COPY --from=builder /build/buckets/b25/ /usr/share/nginx/html/rpm-repo/
COPY --from=builder /build/buckets/b26/ /usr/share/nginx/html/rpm-repo/
COPY --from=builder /build/buckets/b27/ /usr/share/nginx/html/rpm-repo/
COPY --from=builder /build/buckets/b28/ /usr/share/nginx/html/rpm-repo/
COPY --from=builder /build/buckets/b29/ /usr/share/nginx/html/rpm-repo/
COPY --from=builder /build/buckets/b30/ /usr/share/nginx/html/rpm-repo/
COPY --from=builder /build/buckets/b31/ /usr/share/nginx/html/rpm-repo/

# repodata last, as its own small layer (regenerated every build).
COPY --from=builder /build/flat/repodata/ /usr/share/nginx/html/rpm-repo/repodata/

EXPOSE 8080

CMD ["nginx", "-g", "daemon off;"]
